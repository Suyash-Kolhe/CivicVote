rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "suyashkolhe15@gmail.com" && request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidFeedback(data) {
      return data.keys().hasAll(['name', 'email', 'feedback', 'type', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.feedback is string && data.feedback.size() > 0 && data.feedback.size() <= 1000 &&
             data.type in ['suggestion', 'issue'] &&
             data.createdAt == request.time;
    }

    function isValidQuizResult(data) {
      return data.keys().hasAll(['userId', 'score', 'total', 'timestamp']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.score is number && data.score >= 0 &&
             data.total is number && data.total > 0 &&
             data.timestamp == request.time;
    }

    // --- Path Definitions ---

    match /feedback/{feedbackId} {
      // Create is the only allowed write for general users
      allow create: if isSignedIn() && 
                      isValidFeedback(incoming()) && 
                      isValidId(feedbackId);
      
      // Updates are locked for feedback - once submitted, it is a record of truth
      allow update, delete: if isAdmin();
      
      allow get, list: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      match /quiz_results/{resultId} {
        allow read, list: if isOwner(userId) || isAdmin();
        // Create is atomic and uses server timestamp
        allow create: if isOwner(userId) && 
                        isValidQuizResult(incoming()) && 
                        isValidId(resultId);
        // Scores are immutable once recorded
        allow update: if false;
        allow delete: if isAdmin();
      }
    }
  }
}
